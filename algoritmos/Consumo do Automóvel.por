programa { 
  funcao inicio() {
    real distancia
    real litros
    real consumo_medio
    escreva ("digite a distancia percorrida em km:")
    leia (distancia)

    escreva ("quantos litros foram gastos?:")
    leia (litros)

    consumo_medio = distancia / litros

    escreva ("o consumo medio de gasolina foi:", consumo_medio,"km/1")
    
  }
}
